# Postgres (infra/docker-compose.yml "postgres" service)
POSTGRES_DB=code_challenger
POSTGRES_SUPERUSER_PASSWORD=change_me

# Per-role connection strings, created by infra/db/migrations/0002_roles_grants.ts
# (api_role: no users/sessions access for worker; worker_role: no users/sessions access;
# migrator_role: DDL only, used at deploy/migrate time)
DATABASE_URL_MIGRATOR=postgres://migrator_role:change_me@localhost:5432/code_challenger
DATABASE_URL_API=postgres://api_role:change_me@localhost:5432/code_challenger
DATABASE_URL_WORKER=postgres://worker_role:change_me@localhost:5432/code_challenger

# Sessions (apps/api/src/platform/sessions.ts)
SESSION_COOKIE_SECRET=change_me_to_a_long_random_string

# Ports
API_PORT=3000
WEB_PORT=5173

NODE_ENV=development
