{
  "name": "code-challenger",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/contracts",
    "apps/api",
    "apps/worker",
    "apps/web"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present && tsc -p infra/db/tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:hostile": "vitest run --project hostile",
    "db:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d postgres",
    "db:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "db:migrate": "tsx infra/db/migrate.ts",
    "db:seed": "tsx infra/db/seed.ts",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:worker": "npm run dev --workspace apps/worker",
    "dev:web": "npm run dev --workspace apps/web"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-functional": "^7.1.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "kysely": "^0.29.4",
    "pg": "^8.22.0"
  }
}
